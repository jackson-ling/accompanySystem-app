/* pages/register/register.wxss */

.container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 头部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  position: relative;
}

.header-left {
  width: 40rpx;
  height: 40rpx;
}

.logo {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

/* 表单区域 */
.form-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 0;
}

/* 输入框组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-sizing: border-box;
  border: 1rpx solid #ebedf0;
  transition: border-color 0.3s;
}

.input-wrapper:focus-within {
  border-color: #409eff;
  background-color: #ffffff;
}

.code-wrapper {
  padding-right: 10rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
  width: 140rpx;
  font-weight: 500;
  flex-shrink: 0;
  text-align: left;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

.input-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: color 0.3s;
}

.code-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: all 0.3s;
  white-space: nowrap;
}

.code-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.code-btn.disabled {
  background-color: #cccccc;
  opacity: 0.6;
}

/* 注册按钮 */
.register-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
  transition: all 0.3s;
  position: relative;
}

.register-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(64, 158, 255, 0.4);
}

.register-btn.disabled {
  background: #f5f5f5 !important;
  color: #cccccc !important;
  box-shadow: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* 登录链接 */
.login-link {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
}

.login-link .link {
  color: #409eff;
  margin-left: 8rpx;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.agreement-checkbox {
  transform: scale(0.75);
  flex-shrink: 0;
  margin-right: 8rpx;
}

.agreement-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
  text-align: center;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  white-space: nowrap;
}

.agreement-text text {
  white-space: nowrap;
}

.link {
  color: #409eff;
}