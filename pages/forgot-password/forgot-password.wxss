/* pages/forgot-password/forgot-password.wxss */

.container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 头部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  position: relative;
}

.logo {
  margin-bottom: 24rpx;
}

.lang-btn {
  position: absolute;
  right: 0;
  top: 20rpx;
  padding: 8rpx 16rpx;
  background-color: #f5f7fa;
  border-radius: 20rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.lang-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.lang-text {
  font-size: 24rpx;
  color: #409eff;
  font-weight: 500;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

/* 表单区域 */
.form-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 0;
}

/* 输入框组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-sizing: border-box;
  border: 1rpx solid #ebedf0;
  transition: border-color 0.3s;
}

.input-wrapper:focus-within {
  border-color: #409eff;
  background-color: #ffffff;
}

.code-wrapper {
  padding-right: 10rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333333;
  width: 140rpx;
  font-weight: 500;
  flex-shrink: 0;
  text-align: left;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

.input-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: color 0.3s;
}

.input-icon-clickable {
  cursor: pointer;
  transition: transform 0.2s, opacity 0.2s;
}

.input-icon-clickable:active {
  transform: scale(0.9);
  opacity: 0.7;
}

.code-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: all 0.3s;
  white-space: nowrap;
}

.code-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.code-btn.disabled {
  background-color: #cccccc;
  opacity: 0.6;
}

/* 提交按钮 */
.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
  transition: all 0.3s;
  position: relative;
}

.submit-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(64, 158, 255, 0.4);
}

.submit-btn.disabled {
  background: #f5f5f5 !important;
  color: #cccccc !important;
  box-shadow: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* 返回登录 */
.back-login {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
}

.back-login .link {
  color: #409eff;
  margin-left: 8rpx;
}