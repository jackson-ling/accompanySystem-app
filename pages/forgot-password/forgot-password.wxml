<!-- pages/forgot-password/forgot-password.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="logo">
      <van-icon name="service-o" size="64" color="#409eff" />
    </view>
    <text class="title">{{translations.title}}</text>
    <!-- 语言切换按钮 -->
    <view class="lang-btn" bindtap="switchLanguage">
      <text class="lang-text">{{currentLang === 'zh-CN' ? 'EN' : '中'}}</text>
    </view>
  </view>

  <!-- 忘记密码表单 -->
  <view class="form-section">
    <!-- 手机号输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <text class="label-text">{{translations.phoneNumber}}</text>
        <input 
          class="input-field" 
          placeholder="{{translations.phonePlaceholder}}" 
          type="number" 
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
        <van-icon 
          name="phone-o" 
          size="20" 
          color="#409eff" 
          class="input-icon input-icon-clickable"
          open-type="getPhoneNumber"
          bindgetphonenumber="getPhoneNumber"
        />
      </view>
    </view>

    <!-- 验证码输入 -->
    <view class="input-group">
      <view class="input-wrapper code-wrapper">
        <text class="label-text">{{translations.verifyCode}}</text>
        <input 
          class="input-field" 
          placeholder="{{translations.codePlaceholder}}" 
          type="number" 
          maxlength="6"
          value="{{verifyCode}}"
          bindinput="onVerifyCodeInput"
        />
        <view class="code-btn {{canSendCode ? '' : 'disabled'}}" bindtap="sendVerifyCode">
          <text>{{codeButtonText}}</text>
        </view>
      </view>
    </view>

    <!-- 新密码输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <text class="label-text">{{translations.newPassword}}</text>
        <input 
          class="input-field" 
          placeholder="{{translations.passwordPlaceholder}}" 
          password="{{!showPassword}}"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
        />
        <van-icon name="eye-o" size="20" color="{{showPassword ? '#409eff' : '#999'}}" class="input-icon" bindtap="togglePassword" />
      </view>
    </view>

    <!-- 确认密码输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <text class="label-text">{{translations.confirmPassword}}</text>
        <input 
          class="input-field" 
          placeholder="{{translations.confirmPasswordPlaceholder}}" 
          password="{{!showConfirmPassword}}"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
        <van-icon name="eye-o" size="20" color="{{showConfirmPassword ? '#409eff' : '#999'}}" class="input-icon" bindtap="toggleConfirmPassword" />
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="handleSubmit">
      <text>{{loading ? translations.submitting : translations.submit}}</text>
    </view>

    <!-- 返回登录 -->
    <view class="back-login">
      <text>{{translations.rememberPassword}}</text>
      <text class="link" bindtap="goToLogin">{{translations.backToLogin}}</text>
    </view>
  </view>
</view>