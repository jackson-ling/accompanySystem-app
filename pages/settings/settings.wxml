<!-- pages/settings/settings.wxml -->
<view class="settings-page">
  <!-- 头部导航 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="title">{{translations.title}}</text>
    <view class="placeholder"></view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 账户设置组 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="handleChangeAvatar">
        <view class="left">{{translations.changeAvatar}}</view>
        <view class="right">
          <image class="avatar" src="{{userInfo.avatar || 'https://placehold.co/32x32/409eff/ffffff?text=U'}}" mode="aspectFill" />
          <van-icon name="arrow" size="16" color="#c0c4cc" />
        </view>
      </view>
      <view class="menu-item" bindtap="handleChangeNickname">
        <view class="left">{{translations.changeNickname}}</view>
        <view class="right">
          <text class="value">{{userInfo.nickname || ''}}</text>
          <van-icon name="arrow" size="16" color="#c0c4cc" />
        </view>
      </view>
      <view class="menu-item" bindtap="handleChangePassword">
        <view class="left">{{translations.changePassword}}</view>
        <van-icon name="arrow" size="16" color="#c0c4cc" />
      </view>
    </view>

    <!-- 语言设置组 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="handleLanguage">
        <view class="left">{{translations.languageSwitch}}</view>
        <view class="right">
          <text class="value">{{currentLanguage === 'zh-CN' ? translations.chinese : translations.english}}</text>
          <van-icon name="arrow" size="16" color="#c0c4cc" />
        </view>
      </view>
    </view>

    <!-- 关于组 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="handleAbout">
        <view class="left">{{translations.about}}</view>
        <van-icon name="arrow" size="16" color="#c0c4cc" />
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="menu-group">
      <view class="menu-item center-text" bindtap="handleLogout">
        {{translations.logout}}
      </view>
    </view>

    <!-- 注销账号 -->
    <view class="menu-group">
      <view class="menu-item center-text danger-text" bindtap="handleDeleteAccount">
        {{translations.deleteAccount}}
      </view>
    </view>
  </view>

  <!-- 语言选择器 -->
  <van-action-sheet
    show="{{showLanguagePicker}}"
    actions="{{languageOptions}}"
    cancel-text="{{translations.commonCancel}}"
    bind:select="onLanguageSelect"
    bind:cancel="onLanguageCancel"
  />
</view>

<!-- 昵称修改弹窗 -->
<van-popup
  show="{{showNicknameDialog}}"
  position="center"
  round
  bind:close="handleNicknameDialogCancel"
  custom-class="nickname-popup"
>
  <view class="nickname-dialog">
    <view class="dialog-header">
      <text class="dialog-title">{{translations.changeNickname}}</text>
      <van-icon name="cross" size="20" color="#999" bindtap="handleNicknameDialogCancel" />
    </view>
    
    <view class="dialog-body">
      <van-field
        value="{{newNickname}}"
        placeholder="{{translations.nicknamePlaceholder}}"
        bind:input="handleNicknameInput"
        border="{{false}}"
        type="text"
        clearable
      />
    </view>
    
    <view class="dialog-footer">
      <van-button plain type="default" round bindtap="handleNicknameDialogCancel">
        {{translations.commonCancel}}
      </van-button>
      <van-button type="primary" round bindtap="submitNicknameChange">
        {{translations.commonConfirm}}
      </van-button>
    </view>
  </view>
</van-popup>