/* pages/settings/settings.wxss */
.settings-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  display: flex;
  flex-direction: column;
}

/* 头部导航 */
.header {
  background-color: #fff;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 24px;
}

.title {
  font-size: 17px;
  font-weight: 500;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 24px;
}

/* 内容区域 */
.content {
  padding: 12px;
}

/* 菜单组 */
.menu-group {
  background-color: #fff;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 20px;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid #f5f7fa;
  font-size: 15px;
  color: #333;
  cursor: pointer;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-item .left {
  display: flex;
  align-items: center;
}

.menu-item .right {
  display: flex;
  align-items: center;
  gap: 4px;
}

.menu-item .value {
  color: #909399;
  font-size: 14px;
}

.menu-item.center-text {
  justify-content: center;
  font-weight: 500;
}

.menu-item.danger-text {
  color: #f56c6c;
}

/* 头像 */
.avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #f5f7fa;
}

/* 对话框内容 */
.dialog-content {
  padding: 20px;
}

/* 昵称修改弹窗 */
.nickname-popup {
  width: 75% !important;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.nickname-dialog {
  background-color: #fff;
}

.dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.dialog-body {
  padding: 32rpx;
}

.dialog-body :deep(.van-field) {
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
}

.dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  justify-content: center;
}

.dialog-footer .van-button {
  flex: 0 0 auto !important;
  width: auto !important;
  min-width: 120rpx !important;
  height: 64rpx !important;
  font-size: 28rpx !important;
  padding: 0 32rpx !important;
}

.dialog-footer .van-button__text {
  font-size: 28rpx !important;
  white-space: nowrap !important;
}

.dialog-footer .van-button--plain {
  border-width: 1rpx !important;
  border-color: #409eff !important;
  color: #409eff !important;
}

.dialog-footer .van-button--primary {
  background-color: #409eff !important;
  border-color: #409eff !important;
}