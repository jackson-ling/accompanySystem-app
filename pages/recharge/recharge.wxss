/* pages/recharge/recharge.wxss */

.recharge-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 头部导航 */
.header {
  background-color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.header-right {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

/* 内容区域 */
.content {
  padding: 32rpx;
}

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #2979ff 0%, #4facfe 100%);
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  color: #fff;
  margin-bottom: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(41, 121, 255, 0.3);
}

.balance-card .label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
  display: block;
}

.balance-card .amount {
  font-size: 64rpx;
  font-weight: bold;
  display: block;
}

/* 充值金额选择 */
.recharge-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 32rpx;
  display: block;
}

.amount-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.amount-item {
  background-color: #fff;
  border: 2rpx solid #e4e7ed;
  border-radius: 16rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  cursor: pointer;
}

.amount-item .value {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.amount-item.active {
  background-color: #ecf5ff;
  border-color: #409eff;
}

.amount-item.active .value {
  color: #409eff;
}

.amount-item.custom {
  font-size: 28rpx;
}

.custom-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.custom-input {
  border: none;
  outline: none;
  background: transparent;
  width: 160rpx;
  font-size: 40rpx;
  color: #409eff;
  text-align: center;
  font-weight: 600;
}

.custom-input::placeholder {
  color: #a8abb2;
  font-size: 28rpx;
  text-align: center;
  font-weight: normal;
}

/* 支付方式 */
.pay-method {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 80rpx;
}

.pay-method .section-title {
  margin-bottom: 24rpx;
}

.method-item {
  background-color: #fff;
  padding: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #e4e7ed;
}

.method-item .left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.method-item .text {
  font-size: 32rpx;
  color: #333;
}

/* 充值按钮 */
.btn-container {
  margin-top: auto;
}

.submit-btn {
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.3);
}