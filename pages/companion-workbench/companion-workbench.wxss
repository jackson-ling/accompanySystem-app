/* pages/companion-workbench/companion-workbench.wxss */

.workbench-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 头部导航 */
.header {
  background-color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.placeholder {
  width: 48rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #2979ff 0%, #4facfe 100%);
  margin: 32rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(41, 121, 255, 0.3);
}

.card-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-box {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background-color: rgba(255, 255, 255, 0.2);
}

.edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: #409eff;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.info-box {
  flex: 1;
  color: #fff;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-indicator.online {
  background: rgba(19, 206, 102, 0.3);
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
}

.status-indicator.online .dot {
  background: #13ce66;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.divider {
  opacity: 0.5;
}

.edit-hint-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.toggle-box {
  flex-shrink: 0;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin: 32rpx;
}

.stat-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item .value {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-item .unit {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.stat-item .label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 菜单网格 */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin: 0 32rpx 32rpx;
}

.menu-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.icon-box.green {
  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);
}

.icon-box.blue {
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
}

.icon-box.orange {
  background: linear-gradient(135deg, #e6a23c 0%, #ebb563 100%);
}

.menu-item .label {
  display: block;
  font-size: 26rpx;
  color: #333;
}

/* 待处理订单 */
.recent-orders {
  margin: 0 32rpx 32rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #999;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-body {
  padding: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #666;
}

.info-row .value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.time-row .value {
  color: #409eff;
  font-weight: 500;
}

.card-footer {
  padding: 16rpx 24rpx;
  background: #f9f9f9;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 64rpx !important;
  font-size: 26rpx !important;
}

.action-btn.primary {
  background: #409eff !important;
  border-color: #409eff !important;
  color: #fff !important;
}

.empty-state {
  padding: 80rpx 0;
}