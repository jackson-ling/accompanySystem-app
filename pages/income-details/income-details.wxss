/* pages/income-details/income-details.wxss */

.income-details-page {
  min-height: 100vh;
  background-color: #f5f7fa;
}

/* 头部导航 */
.header {
  background-color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  width: 48rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.placeholder {
  width: 48rpx;
}

/* 概览卡片 */
.overview-card {
  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);
  margin: 32rpx;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(103, 194, 58, 0.3);
}

.total-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 16rpx;
}

.total-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 48rpx;
}

.stats-row {
  display: flex;
  gap: 48rpx;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat .label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat .value {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

/* 收入记录列表 */
.record-list {
  padding: 0 32rpx 32rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
  color: #999;
}

.empty-state {
  padding: 80rpx 0;
}

.record-list-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 记录项 */
.record-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e6f7ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.status {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.status.completed {
  background: #f0f9ff;
  color: #67c23a;
}

.status.pending {
  background: #fdf6ec;
  color: #e6a23c;
}

.status.cancelled {
  background: #fef0f0;
  color: #f56c6c;
}

.bottom {
  font-size: 24rpx;
  color: #999;
}

.right-column {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.view-detail {
  font-size: 24rpx;
  color: #409eff;
}

.amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #67c23a;
}