.container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: calc(30rpx + constant(safe-area-inset-top));
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f5f5f5;
}

.header-left {
  width: 80rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.header-right {
  width: 80rpx;
}

/* Banner */
.banner-section {
  padding: 30rpx;
  background-color: #fff;
}

.banner-content {
  height: 200rpx;
  background: linear-gradient(135deg, #409eff, #79bbff);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}

.banner-text {
  color: #fff;
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.sub-title {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  background-color: #fff;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 20rpx;
}

.sort-item {
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.sort-item.active {
  color: #409eff;
  font-weight: bold;
}

/* 服务列表 */
.service-list {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-item {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  gap: 24rpx;
}

.service-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.info-top .service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.info-top .service-desc {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  display: block;
}

.info-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 16rpx;
}

.service-meta .meta-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.service-meta .meta-row.secondary {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  gap: 16rpx;
}

.service-meta .meta-row .service-price {
  color: #f56c6c;
  font-size: 36rpx;
  font-weight: bold;
}

.service-meta .meta-row .service-sales {
  color: #999;
}

.service-meta .meta-row .service-duration {
  color: #999;
}

.select-btn {
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.2);
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 抽屉 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.drawer-content {
  width: 100%;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.header-left,
.header-right {
  width: 60rpx;
  display: flex;
  align-items: center;
}

.header-right {
  justify-content: flex-end;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.drawer-body {
  flex: 1;
  overflow: hidden;
}

.companion-scroll {
  height: 100%;
  padding: 20rpx 0;
}

.companion-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 20rpx;
}

.companion-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.companion-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.stats-row {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #666;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.intro {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}