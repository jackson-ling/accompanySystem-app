<!-- pages/favorites/favorites.wxml -->
<view class="favorites-page">
  <!-- 头部导航 -->
  <view class="header">
    <view class="back-icon" bindtap="goBack">
      <van-icon name="arrow-left" size="24" color="#333" />
    </view>
    <text class="title">{{translations.title}}</text>
    <view class="placeholder"></view>
  </view>

  <!-- 收藏列表内容 -->
  <view class="content">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <van-loading type="spinner" size="24" />
      <text>{{translations.loading}}</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{isEmpty}}" class="empty-state">
      <van-empty description="{{translations.emptyTip}}" />
    </view>

    <!-- 陪诊师列表 -->
    <view wx:else class="companion-list">
      <view 
        wx:for="{{favoriteCompanions}}" 
        wx:key="id" 
        class="companion-card"
        data-id="{{item.id}}"
        bindtap="goToDetail"
      >
        <view class="card-left">
          <image class="avatar" src="{{item.avatar}}" mode="aspectFill" />
        </view>
        <view class="card-right">
          <view class="info-content">
            <view class="row-1">
              <text class="name">{{item.name}}</text>
              <van-icon wx:if="{{item.gender === 'female'}}" name="woman" size="14" color="#f56c6c" />
              <van-icon wx:else name="man" size="14" color="#409eff" />
              <text wx:if="{{item.age}}" class="age">{{item.age}}{{translations.yearsOld}}</text>
              <text wx:if="{{item.experience}}" class="experience-tag">{{item.experience}}</text>
            </view>
            <view class="stats-row">
              <view class="stat-item">
                <van-icon name="bill" size="14" />
                <text>{{item.orders || 0}}{{translations.orders}}</text>
              </view>
              <view class="stat-item">
                <van-icon name="star" size="14" color="#F7BA2A" />
                <text class="score-text">{{item.score || 0}}</text>
              </view>
              <view class="stat-item">
                <van-icon name="chat" size="14" />
                <text>{{item.comments || 0}}{{translations.comments}}</text>
              </view>
            </view>
          </view>
          <view class="action-column">
            <view 
              class="heart-action" 
              data-id="{{item.id}}"
              catchtap="handleToggleFavorite"
            >
              <van-icon name="like" size="20" color="#F56C6C" />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>