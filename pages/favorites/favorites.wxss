/* pages/favorites/favorites.wxss */
.favorites-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  display: flex;
  flex-direction: column;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 10px 15px;
}

/* 加载状态 */
.loading-state {
  padding-top: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  color: #909399;
  font-size: 14px;
}

/* 空状态 */
.empty-state {
  padding-top: 60px;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 陪诊师列表 */
.companion-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* 陪诊师卡片 */
.companion-card {
  background-color: #fff;
  border-radius: 10px;
  padding: 15px;
  display: flex;
  gap: 15px;
  cursor: pointer;
  align-items: center;
}

.companion-card:active {
  background-color: #f9f9f9;
}

.card-left {
  flex-shrink: 0;
}

.avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background-color: #f5f7fa;
}

.card-right {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
}

.row-1 {
  display: flex;
  align-items: center;
}

.name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-right: 8px;
}

.age {
  font-size: 13px;
  color: #999;
  margin-right: 8px;
}

.experience-tag {
  font-size: 11px;
  color: #fff;
  background-color: #409eff;
  padding: 1px 6px;
  border-radius: 4px;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-top: 4px;
}

.stat-item {
  display: flex;
  align-items: center;
  font-size: 12px;
  color: #909399;
  gap: 4px;
}

.stat-item text {
  color: #909399;
}

.score-text {
  color: #F7BA2A !important;
  font-weight: 600;
}

.action-column {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  margin-left: 10px;
}

.heart-action {
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  padding: 8px;
  border-radius: 50%;
  transition: background-color 0.3s;
}

.heart-action:active {
  background-color: #f5f7fa;
}