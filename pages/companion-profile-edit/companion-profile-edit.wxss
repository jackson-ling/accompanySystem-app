/* pages/companion-profile-edit/companion-profile-edit.wxss */

.profile-edit-page {
  min-height: 100vh;
  background-color: #f5f7fa;
}

/* 头部导航 */
.header {
  background-color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  width: 48rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.save-btn {
  width: 80rpx;
  text-align: right;
  font-size: 28rpx;
  color: #409eff;
  cursor: pointer;
}

/* 表单内容 */
.form-content {
  padding: 32rpx;
}

/* 头像区域 */
.avatar-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.avatar-wrapper {
  position: relative;
  cursor: pointer;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.edit-overlay {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.tip {
  font-size: 24rpx;
  color: #999;
}

/* 表单组 */
.form-group {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.vertical {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.custom-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid transparent;
  transition: border-color 0.3s;
}

.custom-input:focus {
  border-color: #409eff;
  background-color: #fff;
}

.custom-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid transparent;
  transition: border-color 0.3s;
}

.custom-textarea:focus {
  border-color: #409eff;
  background-color: #fff;
}

.word-count {
  margin-top: 12rpx;
  text-align: right;
  font-size: 24rpx;
  color: #999;
}