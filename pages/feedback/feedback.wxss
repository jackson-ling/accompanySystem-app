/* pages/feedback/feedback.wxss */
.feedback-page {
  min-height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  padding-bottom: 40px;
}

/* 头部导航 */
.header {
  height: 44px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-icon {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.title {
  font-size: 17px;
  font-weight: 500;
  color: #333;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 20px;
}

/* 内容区域 */
.content {
  background-color: #fff;
  padding: 20px 16px 40px;
}

/* 表单组 */
.form-group {
  margin-bottom: 24px;
}

.label {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 12px;
  display: block;
}

/* 自定义文本域 */
.custom-textarea {
  width: 100%;
  min-height: 120px;
  background-color: #f7f8fa;
  border-radius: 12px;
  padding: 12px;
  box-sizing: border-box;
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  border: none;
}

.custom-textarea::placeholder {
  color: #909399;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: #909399;
  margin-top: 4px;
}

/* 自定义输入框 */
.custom-input {
  width: 100%;
  height: 48px;
  background-color: #f7f8fa;
  border-radius: 12px;
  padding: 0 16px;
  box-sizing: border-box;
  font-size: 14px;
  color: #333;
  border: none;
}

.custom-input::placeholder {
  color: #909399;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 48px;
  font-size: 16px;
  margin-top: 30px;
  border-radius: 24px;
  box-shadow: 0 4px 12px rgba(64, 158, 255, 0.3);
}