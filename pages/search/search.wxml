<!-- pages/search/search.wxml -->
<view class="container">
  <!-- 搜索头部 -->
  <view class="search-header">
    <view class="header-left" bindtap="goBack">
      <van-icon name="arrow-left" size="20" color="#333" />
    </view>
    <view class="search-input-wrapper">
      <van-icon name="search" size="16" color="#999" />
      <input class="search-input" placeholder="搜索您需要的服务" value="{{searchText}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="performSearch" />
      <van-icon wx:if="{{searchText}}" name="clear" size="16" color="#999" bindtap="clearSearch" />
    </view>
    <view class="header-right" bindtap="performSearch">
      <text class="search-btn">搜索</text>
    </view>
  </view>

  <!-- 搜索内容 -->
  <view class="search-content">
    <!-- 默认视图（历史搜索和猜你喜欢） -->
    <view wx:if="{{!isSearching && !showResults}}" class="default-view">
      <!-- 历史搜索 -->
      <view wx:if="{{historyList.length > 0}}" class="section">
        <view class="section-header">
          <text class="title">历史搜索</text>
          <text class="clear-btn" bindtap="clearHistory">清空</text>
        </view>
        <view class="tags-container">
          <view wx:for="{{historyList}}" wx:key="index" class="tag-item" bindtap="performSearch" data-text="{{item}}">
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 猜你喜欢 -->
      <view class="section">
        <view class="section-header">
          <text class="title">猜你喜欢</text>
        </view>
        <view class="tags-container">
          <view wx:for="{{allServices}}" wx:key="id" class="tag-item" bindtap="performSearch" data-text="{{item.name}}">
            <text>{{item.name}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 搜索结果 -->
    <view wx:else class="results-view">
      <view wx:if="{{filteredServices.length === 0 && !loading}}" class="empty-state">
        <van-icon name="search" size="80" color="#ddd" />
        <text class="empty-text">暂无相关服务</text>
      </view>
      <view wx:else class="service-list">
        <view class="service-card" wx:for="{{filteredServices}}" wx:key="id" bindtap="goToServiceDetail" data-service="{{item}}">
          <image class="service-image" src="{{item.image}}" mode="aspectFill" />
          <view class="service-info">
            <view class="info-top">
              <text class="service-name">{{item.name}}</text>
              <text class="service-desc">{{item.description}}</text>
            </view>
            <view class="info-bottom">
              <view class="service-meta">
                <text class="service-price">¥{{item.price}}</text>
              </view>
              <view class="select-btn">
                <text>去预约</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{loading}}" class="loading">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
    </view>
  </view>
</view>