/* pages/ai-chat/ai-chat.wxss */

.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 聊天头部 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  text-align: center;
}

.header-actions {
  width: 40rpx;
  display: flex;
  justify-content: flex-end;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
  padding-bottom: 20rpx;
  box-sizing: border-box;
}

.message-row {
  display: flex;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.message-row.ai-row {
  justify-content: flex-start;
}

.message-row.user-row {
  justify-content: flex-end;
}

.message-bubble {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  max-width: 70%;
}

.ai-bubble {
  flex-direction: row;
}

.user-bubble {
  flex-direction: row-reverse;
}

.ai-avatar,
.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  min-width: 64rpx;
}

.ai-avatar {
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
}

.user-avatar {
  background-color: #f5f7fa;
  border: 2rpx solid #e6e8eb;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.bubble-content {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  box-sizing: border-box;
  max-width: 100%;
}

.ai-bubble .bubble-content {
  background-color: #ffffff;
  color: #333333;
  border-top-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.user-bubble .bubble-content {
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  border-top-right-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
}

/* 建议问题 */
.suggestions {
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.suggestions-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.suggestion-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #409eff;
  transition: all 0.3s;
}

.suggestion-item:active {
  background-color: #409eff;
  color: #ffffff;
  transform: scale(0.95);
}

/* 输入区域 */
.input-area {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background-color: #f5f7fa;
  border-radius: 48rpx;
  padding: 12rpx 20rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.send-btn {
  height: 64rpx;
  width: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  border-radius: 50%;
  transition: all 0.3s;
  flex-shrink: 0;
}

.send-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.send-btn.disabled {
  background-color: #e6e8eb;
  opacity: 0.6;
}

/* 菜单弹窗 */
.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding-top: calc(100rpx + env(safe-area-inset-top));
  padding-right: 30rpx;
}

.menu-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  min-width: 200rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #333333;
  transition: all 0.3s;
}

.menu-item:active {
  background-color: #f5f7fa;
}