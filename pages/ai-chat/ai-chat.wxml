<!-- pages/ai-chat/ai-chat.wxml -->
<view class="container">
  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y="{{true}}" scroll-into-view="{{scrollToView}}" scroll-with-animation="{{true}}">
    <view class="message-row {{item.isMe ? 'user-row' : ''}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <!-- AI消息 -->
      <view class="message-bubble ai-bubble" wx:if="{{!item.isMe}}">
        <view class="ai-avatar">
          <van-icon name="user-circle-o" size="48" color="#409eff" />
        </view>
        <view class="bubble-content">
          <text>{{item.text}}</text>
        </view>
      </view>
      
      <!-- 用户消息 -->
      <view class="message-bubble user-bubble" wx:else>
        <view class="user-avatar">
          <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill" />
          <van-icon wx:else name="user-circle-o" size="36" color="#666" />
        </view>
        <view class="bubble-content">
          <text>{{item.text}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 建议问题 -->
  <view class="suggestions" wx:if="{{suggestions.length > 0 && !hasStarted}}">
    <text class="suggestions-title">{{translations.youWantToAsk}}</text>
    <view class="suggestion-list">
      <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="index" bindtap="sendSuggestion" data-text="{{item}}">
        <van-icon name="question-o" size="14" color="#409eff" />
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 输入框 -->
  <view class="input-area">
    <view class="input-wrapper">
      <view class="clear-btn" bindtap="showMenu" wx:if="{{messages.length > 0}}">
        <van-icon name="delete-o" size="20" color="#f56c6c" />
      </view>
      <view class="chat-icon" wx:else>
        <van-icon name="chat-o" size="20" color="#409eff" />
      </view>
      <input 
        class="input-field" 
        placeholder="{{translations.placeholder}}" 
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        confirm-type="send"
      />
      <view class="send-btn {{canSend ? '' : 'disabled'}}" bindtap="sendMessage">
        <van-icon name="send-gift-o" size="20" color="{{canSend ? '#fff' : '#ccc'}}" />
      </view>
    </view>
  </view>

  <!-- 菜单弹窗 -->
  <view class="menu-mask" wx:if="{{showMenu}}" bindtap="hideMenu">
    <view class="menu-content" catchtap="stopPropagation">
      <view class="menu-item" bindtap="clearHistory">
        <van-icon name="delete-o" size="18" color="#f56c6c" />
        <text>清空聊天记录</text>
      </view>
    </view>
  </view>
</view>