<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 头部区域 -->
  <view class="header-section">
    <view class="user-card" bindtap="handleUserInfoClick">
      <image class="avatar" src="{{userInfo.avatar || 'https://placehold.co/64x64/409eff/ffffff?text=U'}}" mode="aspectFill" />
      <view class="info-content">
        <view class="nickname-row">
          <text class="nickname">{{isLogin ? userInfo.nickname : translations.loginPrompt}}</text>
        </view>
        <text class="phone" wx:if="{{isLogin}}">{{userInfo.phone}}</text>
        <text class="desc" wx:else>{{translations.loginDesc}}</text>
      </view>
      <!-- 设置图标：已登录用户显示设置图标，未登录显示箭头 -->
      <view class="settings-icon-wrapper" wx:if="{{isLogin}}" catchtap="handleSettings">
        <van-icon name="setting-o" size="24" color="#fff" />
      </view>
      <van-icon wx:else name="arrow" size="16" color="#fff" />
    </view>

    <!-- 余额卡片 -->
    <view class="balance-card">
      <view class="balance-info">
        <text class="label">{{translations.accountBalance}}</text>
        <view class="amount-row">
          <text class="amount">¥{{isLogin && userInfo.balance ? userInfo.balance : '0.00'}}</text>
        </view>
      </view>
      <view class="recharge-btn" bindtap="handleRecharge">
        <text>{{translations.recharge}}</text>
      </view>
    </view>
  </view>

  <!-- 订单卡片 -->
  <view class="section-card">
    <view class="card-header" bindtap="goToOrderList">
      <text class="title">{{translations.myOrders}}</text>
      <view class="more">
        <text>{{translations.allOrders}}</text>
        <van-icon name="arrow" size="14" color="#999" />
      </view>
    </view>
    <view class="order-grid">
      <view class="grid-item" bindtap="goToOrderList" data-status="2">
        <view class="icon-wrapper">
          <van-icon name="clock-o" size="28" color="#409eff" />
          <view class="badge" wx:if="{{pendingServiceCount > 0}}">{{pendingServiceCount}}</view>
        </view>
        <text class="label">{{translations.pendingService}}</text>
      </view>
      <view class="grid-item" bindtap="goToOrderList" data-status="3">
        <view class="icon-wrapper">
          <van-icon name="play-circle-o" size="28" color="#e6a23c" />
        </view>
        <text class="label">{{translations.inService}}</text>
      </view>
      <view class="grid-item" bindtap="goToOrderList" data-status="4">
        <view class="icon-wrapper">
          <van-icon name="passed" size="28" color="#67c23a" />
        </view>
        <text class="label">{{translations.completed}}</text>
      </view>
      <view class="grid-item" bindtap="goToOrderList" data-status="5">
        <view class="icon-wrapper">
          <van-icon name="replay" size="28" color="#909399" />
        </view>
        <text class="label">{{translations.refund}}</text>
      </view>
    </view>
  </view>

  <!-- 常用功能菜单 -->
  <view class="section-card menu-list">
    <view class="card-header">
      <text class="title">{{translations.commonFunctions}}</text>
    </view>

    <view class="menu-item" bindtap="handlePatientManagement">
      <view class="left">
        <van-icon name="user-o" size="20" color="#409eff" />
        <text class="text">{{translations.patientManagement}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>

    <view class="menu-item" bindtap="handleFavorites">
      <view class="left">
        <van-icon name="star-o" size="20" color="#f56c6c" />
        <text class="text">{{translations.myFavorites}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>

    <view class="menu-item" bindtap="handleMyReviews">
      <view class="left">
        <van-icon name="comment-o" size="20" color="#e6a23c" />
        <text class="text">{{translations.myReviews}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>

    <!-- 申请成为陪诊师 - 只在非陪诊师时显示 -->
    <view class="menu-item" wx:if="{{!isCompanion}}" bindtap="handleApplyCompanion">
      <view class="left">
        <van-icon name="medal-o" size="20" color="#f56c6c" />
        <text class="text">{{translations.applyCompanion}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>

    <!-- 陪诊师工作台 - 只在陪诊师时显示 -->
    <view class="menu-item" wx:if="{{isCompanion}}" bindtap="handleWorkbench">
      <view class="left">
        <van-icon name="bag-o" size="20" color="#409eff" />
        <text class="text">{{translations.workbench}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>

    <view class="menu-item" bindtap="handleContactService">
      <view class="left">
        <van-icon name="service-o" size="20" color="#e6a23c" />
        <text class="text">{{translations.contactService}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>

    <view class="menu-item" bindtap="handleFeedback">
      <view class="left">
        <van-icon name="chat-o" size="20" color="#409eff" />
        <text class="text">{{translations.feedback}}</text>
      </view>
      <van-icon name="arrow" size="14" color="#c0c4cc" />
    </view>
  </view>
</view>