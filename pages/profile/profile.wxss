/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 头部区域 */
.header-section {
  background: linear-gradient(135deg, #2979ff 0%, #4facfe 100%);
  padding: 80rpx 30rpx 140rpx;
  position: relative;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  overflow: visible;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background-color: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
}

.phone {
  font-size: 28rpx;
  opacity: 0.9;
}

.desc {
  font-size: 28rpx;
  opacity: 0.8;
}

.settings-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
}

/* 余额卡片 */
.balance-card {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: -50rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
}

.balance-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.amount-row {
  display: flex;
  align-items: baseline;
}

.amount {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
}

.recharge-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
}

.recharge-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 通用卡片 */
.section-card {
  margin: 60rpx 30rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-card.menu-list {
  margin-top: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f7fa;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999999;
}

/* 订单网格 */
.order-grid {
  display: flex;
  padding: 40rpx 0;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.icon-wrapper {
  position: relative;
  margin-bottom: 8rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #f56c6c;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  border: 2rpx solid #ffffff;
}

.grid-item .label {
  font-size: 26rpx;
  color: #666666;
}

/* 菜单项 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid #f9f9f9;
}

.left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.text {
  font-size: 30rpx;
  color: #333333;
}