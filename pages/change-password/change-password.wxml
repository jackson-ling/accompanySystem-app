<view class="change-password-page">
  <!-- 表单容器 -->
  <view class="form-container">
    <van-field
      value="{{oldPassword}}"
      type="password"
      label="{{translations.oldPassword}}"
      placeholder="{{translations.oldPasswordPlaceholder}}"
      bind:input="onOldPasswordChange"
      clearable
    />

    <van-field
      value="{{newPassword}}"
      type="password"
      label="{{translations.newPassword}}"
      placeholder="{{translations.newPasswordPlaceholder}}"
      bind:input="onNewPasswordChange"
      clearable
    />

    <van-field
      value="{{confirmPassword}}"
      type="password"
      label="{{translations.confirmPassword}}"
      placeholder="{{translations.confirmPasswordPlaceholder}}"
      bind:input="onConfirmPasswordChange"
      clearable
    />

    <view class="form-actions">
      <van-button
        type="primary"
        round
        block
        bind:click="submitPasswordChange"
        loading="{{loading}}"
      >
        {{translations.submit}}
      </van-button>
    </view>
  </view>
</view>