<!-- pages/login/login.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="logo">
      <van-icon name="service-o" size="64" color="#409eff" />
    </view>
    <text class="title">{{translations.platformTitle}}</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 手机号输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <text class="label-text">{{translations.phoneNumber}}</text>
        <input 
          class="input-field" 
          placeholder="{{translations.pleaseEnterPhone}}" 
          type="number" 
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
        <van-icon name="phone-o" size="20" color="#409eff" class="input-icon" />
      </view>
    </view>

    <!-- 密码输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <text class="label-text">{{translations.password}}</text>
        <input 
          class="input-field" 
          placeholder="{{translations.pleaseEnterPassword}}" 
          password="{{!showPassword}}"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <van-icon name="eye-o" size="20" color="{{showPassword ? '#409eff' : '#999'}}" class="input-icon" bindtap="togglePassword" />
      </view>
      <text class="forgot-pwd" bindtap="goToForgotPassword">{{translations.forgotPassword}}</text>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn {{canLogin ? '' : 'disabled'}}" bindtap="handleLogin">
      <text>{{translations.loginButton}}</text>
    </view>

    <!-- 注册链接 -->
    <view class="register-link">
      <text>{{translations.noAccount}}</text>
      <text class="link" bindtap="goToRegister">{{translations.registerNow}}</text>
    </view>

    <!-- 协议 -->
    <view class="agreement">
      <checkbox class="agreement-checkbox" checked="{{agreed}}" bindtap="toggleAgreement" color="#409eff" />
      <view class="agreement-text" bindtap="handleAgreementClick">
        <text>{{translations.haveReadAgreed}}</text>
        <text class="link">《{{translations.userAgreement}}》</text>
        <text>{{translations.and}}</text>
        <text class="link">《{{translations.privacyPolicy}}》</text>
      </view>
    </view>
  </view>
</view>