<!-- pages/consumption-record/consumption-record.wxml -->
<view class="consumption-record-page">
  <!-- 头部导航 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="title">{{translations.title}}</text>
    <view class="placeholder"></view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <van-loading type="spinner" size="24" />
      <text>{{translations.loading}}</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{isEmpty}}" class="empty-state">
      <van-empty description="{{translations.noRecords}}" />
    </view>

    <!-- 消费记录列表 -->
    <view wx:else class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="item-main">
          <view class="item-left">
            <text class="type {{item.type === 'recharge' ? 'recharge' : 'order'}}">{{item.type === 'recharge' ? translations.recharge : translations.serviceOrder}}</text>
            <text class="title">{{item.title}}</text>
            <text class="time">{{item.time}}</text>
          </view>
          <view class="item-right">
            <text class="amount {{item.amount < 0 ? 'expense' : 'income'}}">{{item.amount}}</text>
            <text class="balance">{{translations.balance}}: {{item.balance}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>