/* pages/companion/companion.wxss */

.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  display: flex;
  align-items: center;
  height: 72rpx;
  background-color: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 30rpx;
  gap: 16rpx;
}

.search-field {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #666666;
  gap: 8rpx;
  position: relative;
  transition: all 0.3s;
}

.filter-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 28rpx;
  width: 1rpx;
  background-color: #eeeeee;
}

.filter-item.active {
  color: #409eff;
  font-weight: bold;
}

.filter-btn {
  color: #409eff;
}

/* 陪诊师列表 */
.companion-list {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.companion-card {
  position: relative;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.companion-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.card-left {
  flex-shrink: 0;
}

.companion-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid #409eff;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.2);
}

.card-right {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-width: 0;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.row-1 {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.gender-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #ffffff;
  flex-shrink: 0;
}

.gender-icon.male {
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
}

.gender-icon.female {
  background: linear-gradient(135deg, #f56c6c 0%, #f78989 100%);
}

.age {
  font-size: 20rpx;
  color: #999999;
  flex-shrink: 0;
}

.experience-tag {
  padding: 2rpx 6rpx;
  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);
  color: #ffffff;
  font-size: 16rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.stats-row {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #999999;
}

.stat-item .score {
  color: #f7ba2a;
  font-weight: bold;
}

.action-column {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.book-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
  text-align: center;
}

.book-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999999;
}

.empty-text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 抽屉通用样式 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.drawer-content {
  width: 100%;
  max-height: 80vh;
  background-color: #ffffff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
  display: flex;
  flex-direction: column;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.header-left,
.header-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-right {
  justify-content: flex-end;
}

.drawer-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 陪诊师头部卡片 */
.companion-header-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 20rpx;
  flex-shrink: 0;
}

.companion-header-card .companion-avatar {
  width: 100rpx;
  height: 100rpx;
}

.companion-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.companion-info .info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.companion-info .name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.companion-info .age {
  font-size: 24rpx;
  color: #999999;
}

.companion-info .experience-tag {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.companion-info .stats-row {
  display: flex;
  gap: 24rpx;
}

.companion-info .stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 服务选择 */
.service-selection {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.service-scroll {
  flex: 1;
  padding: 20rpx 0;
}

.service-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 20rpx;
}

.service-card:active {
  background-color: #f9f9f9;
}

.service-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.service-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.service-desc {
  font-size: 24rpx;
  color: #999999;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.service-price {
  color: #f56c6c;
  font-weight: bold;
  font-size: 32rpx;
}

.select-icon {
  flex-shrink: 0;
}

/* 筛选抽屉 */
.filter-drawer-content {
  width: 100%;
  max-height: 70vh;
  background-color: #ffffff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.filter-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 32rpx;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s;
}

.tag-item.active {
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
}

.filter-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
  font-size: 30rpx;
  transition: all 0.3s;
}

.reset-btn {
  background-color: #f5f7fa;
  color: #666666;
}

.reset-btn:active {
  background-color: #e6e8eb;
}

.confirm-btn {
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
}

.confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.stopPropagation {
  /* 阻止冒泡 */
}