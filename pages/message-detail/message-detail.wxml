<view class="container">
  <!-- 菜单遮罩 -->
  <view class="menu-mask" wx:if="{{showMenu}}" bindtap="toggleMenu"></view>

  <!-- 菜单 -->
  <view class="custom-menu" wx:if="{{showMenu}}">
    <view class="menu-item" wx:if="{{chatType === 'companion'}}" bindtap="handleMenuAction" data-action="delete">
      删除该聊天
    </view>
    <view class="menu-item" bindtap="handleMenuAction" data-action="clear">
      清空聊天记录
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-container" scroll-y="{{true}}" scroll-top="{{scrollTop}}" scroll-into-view="{{scrollIntoView}}" scroll-with-animation="{{true}}">
    <view wx:for="{{messages}}" wx:key="index">
      <!-- 时间分隔符 -->
      <view class="time-divider" wx:if="{{item.time}}">
        <text>{{item.time}}</text>
      </view>

      <!-- 消息行 -->
      <view class="message-row {{item.isMe ? 'right' : 'left'}}" id="msg-{{index}}">
        <!-- 对方头像 -->
        <image 
          wx:if="{{!item.isMe}}" 
          class="avatar {{chatType === 'service' ? 'service-avatar' : chatType === 'system' ? 'system-avatar' : 'companion-avatar'}}"
          src="{{chatType === 'service' ? 'https://placehold.co/100x100/409eff/fff?text=客服' : chatType === 'system' ? 'https://placehold.co/100x100/67c23a/fff?text=系统' : otherAvatar}}"
          mode="aspectFill"
        />

        <!-- 用户头像 -->
        <image 
          wx:else 
          class="avatar user-avatar"
          src="{{userAvatar}}"
          mode="aspectFill"
        />

        <!-- 消息气泡 -->
        <view class="bubble">
          <image wx:if="{{item.type === 'image' && item.imageUrl}}" src="{{item.imageUrl}}" mode="widthFix" bindtap="previewImage" data-url="{{item.imageUrl}}" />
          <text wx:else>{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{messages.length === 0}}" class="empty-state">
      <text>暂无消息</text>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="chat-input-area" wx:if="{{chatType === 'service' || chatType === 'companion'}}">
    <view class="input-box">
      <input 
        class="chat-input" 
        placeholder="请输入消息..." 
        value="{{inputText}}" 
        bindinput="onInput"
        bindconfirm="sendMessage"
        confirm-type="send"
      />
    </view>
    <view class="image-btn" bindtap="showActionSheet">
      <van-icon name="plus" size="20" color="#666" />
    </view>
    <view 
      class="send-btn {{inputText.trim() ? '' : 'disabled'}}" 
      bindtap="sendMessage"
    >
      <text>发送</text>
    </view>
  </view>

  <!-- 功能选择弹窗 -->
  <view class="action-sheet-mask" wx:if="{{showActionSheet}}" bindtap="hideActionSheet">
    <view class="action-sheet-content" catchtap="stopPropagation">
      <view class="action-sheet-header">
        <text class="cancel-text" bindtap="hideActionSheet">取消</text>
      </view>
      <view class="action-sheet-body">
        <view class="action-item" bindtap="chooseImage" data-source="album">
          <van-icon name="photo-o" size="24" color="#409eff" />
          <text>相册</text>
        </view>
        <view class="action-item" bindtap="chooseImage" data-source="camera">
          <van-icon name="photograph" size="24" color="#409eff" />
          <text>拍摄</text>
        </view>
      </view>
    </view>
  </view>
</view>