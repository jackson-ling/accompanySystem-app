.container {
  background-color: #f7f8fa;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.custom-menu {
  position: absolute;
  top: 120rpx;
  right: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 1001;
  overflow: hidden;
  min-width: 240rpx;
}

.menu-item {
  padding: 30rpx 40rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f5f5f5;
}

.chat-container {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 140rpx;
  overflow-y: auto;
  background-color: #f7f8fa;
  min-height: 0;
}

.time-divider {
  text-align: center;
  margin: 30rpx 0;
}

.time-divider text {
  background-color: rgba(0, 0, 0, 0.1);
  color: #999;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.message-row {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message-row.left {
  flex-direction: row;
}

.message-row.right {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.service-avatar {
  background: linear-gradient(135deg, #409eff, #79bbff);
}

.system-avatar {
  background: linear-gradient(135deg, #67c23a, #95d475);
}

.companion-avatar {
  background: linear-gradient(135deg, #ff99cc, #ff6699);
}

.user-avatar {
  background: linear-gradient(135deg, #f56c6c, #f89898);
}

.message-row.left .avatar {
  margin-right: 20rpx;
}

.message-row.right .avatar {
  margin-left: 20rpx;
}

.bubble {
  max-width: 480rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

.bubble image {
  max-width: 100%;
  border-radius: 8rpx;
}

.message-row.left .bubble {
  background-color: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}

.message-row.right .bubble {
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
  border-top-right-radius: 4rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.chat-input-area {
  background-color: #fff;
  padding: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-box {
  flex: 1;
}

.chat-input {
  background-color: #f5f7fa;
  border: 1rpx solid #e4e7ed;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.chat-input::placeholder {
  color: #999;
}

.image-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f7fa;
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.3s;
}

.image-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.send-btn {
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
}

.send-btn.disabled {
  opacity: 0.5;
}

/* 功能选择弹窗 */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1002;
  display: flex;
  align-items: flex-end;
}

.action-sheet-content {
  width: 100%;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.action-sheet-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.cancel-text {
  font-size: 28rpx;
  color: #666;
}

.action-sheet-body {
  padding: 40rpx 30rpx;
  display: flex;
  gap: 40rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 20rpx;
  background-color: #f7f8fa;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.action-item:active {
  background-color: #e6e8eb;
  transform: scale(0.98);
}

.action-item text {
  font-size: 26rpx;
  color: #333;
}