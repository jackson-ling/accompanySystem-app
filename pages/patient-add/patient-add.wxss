.container {
  background-color: #f7f8fa;
  min-height: 100vh;
}

.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: calc(30rpx + constant(safe-area-inset-top));
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f5f5f5;
}

.header-left {
  width: 60rpx;
}

.nav-header .title {
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-header .placeholder {
  width: 60rpx;
}

.form-container {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 20rpx 0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  width: 200rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-item .input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-item .input::placeholder {
  color: #999;
}

.form-item.switch-item {
  justify-content: space-between;
}

.submit-container {
  padding: 40rpx 30rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 30rpx;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.3);
}

.submit-btn.disabled {
  opacity: 0.5;
  box-shadow: none;
}