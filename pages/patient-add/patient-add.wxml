<view class="container">
  <!-- 页面头部 -->
  <view class="nav-header">
    <view class="header-left"></view>
    <text class="title">{{isEdit ? '编辑就诊人' : '添加就诊人'}}</text>
    <view class="placeholder"></view>
  </view>

  <!-- 表单区域 -->
  <view class="form-container">
    <view class="form-item">
      <text class="label">姓名</text>
      <input 
        class="input" 
        placeholder="请输入姓名" 
        value="{{formData.name}}" 
        bindinput="onInput" 
        data-field="name" 
        maxlength="10"
      />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input 
        class="input" 
        type="number" 
        placeholder="请输入手机号" 
        value="{{formData.phone}}" 
        bindinput="onInput" 
        data-field="phone" 
        maxlength="11"
      />
    </view>

    <view class="form-item">
      <text class="label">关系</text>
      <input 
        class="input" 
        placeholder="请输入关系（如：本人、家属等）" 
        value="{{formData.relationship}}" 
        bindinput="onInput" 
        data-field="relationship" 
        maxlength="10"
      />
    </view>

    <view class="form-item">
      <text class="label">地址</text>
      <input 
        class="input" 
        placeholder="请输入地址" 
        value="{{formData.address}}" 
        bindinput="onInput" 
        data-field="address" 
        maxlength="50"
      />
    </view>

    <view class="form-item switch-item">
      <text class="label">设为默认就诊人</text>
      <switch 
        checked="{{formData.default}}" 
        bindchange="onSwitchChange" 
        color="#409eff"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-container">
    <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="handleSubmit">
      <text>{{isEdit ? '保存' : '添加'}}</text>
    </view>
  </view>
</view>