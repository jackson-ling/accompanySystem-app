/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 位置栏 */
.location-bar {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 500rpx;
}

.location-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 搜索栏 */
.search-bar {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  border-radius: 36rpx;
  margin: 20rpx 30rpx 30rpx;
  border: 1rpx solid #e5e5e5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  margin-right: 16rpx;
  display: flex;
  align-items: center;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999999;
  flex: 1;
}

/* 轮播图 */
.carousel-section {
  margin-bottom: 30rpx;
}

.carousel {
  width: 100%;
  height: 360rpx;
}

.carousel-image {
  width: 100%;
  height: 100%;
}

/* 导航网格 */
.nav-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background-color: #ffffff;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.nav-item {
  display: flex;
  justify-content: center;
}

.nav-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  cursor: pointer;
  transition: transform 0.3s;
}

.nav-content:active {
  transform: scale(0.95);
}

.nav-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.08);
}

.companion-icon {
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
}

.agency-icon {
  background: linear-gradient(135deg, #67c23a 0%, #85ce61 100%);
}

.doctor-icon {
  background: linear-gradient(135deg, #e6a23c 0%, #f0a20a 100%);
}

.order-icon {
  background: linear-gradient(135deg, #f56c6c 0%, #ff8a8a 100%);
}

.nav-text {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 医院列表 */
.hospital-section {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.hospital-scroll {
  width: 100%;
  white-space: nowrap;
}

.hospital-list {
  display: inline-flex;
  gap: 20rpx;
}

.hospital-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  min-width: 160rpx;
  flex-shrink: 0;
}

.hospital-card:active {
  transform: scale(0.95);
}

.hospital-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.2);
}

.hospital-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  text-align: center;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hospital-distance {
  font-size: 22rpx;
  color: #f56c6c;
  margin-top: 8rpx;
  font-weight: 500;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  position: relative;
  padding-left: 0;
  white-space: nowrap;
}

.section-title::before {
  content: '';
  position: absolute;
  left: -20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  border-radius: 3rpx;
}

.more-link {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #999999;
  white-space: nowrap;
}

.arrow {
  font-size: 24rpx;
  color: #409eff;
}

/* 服务列表 */
.service-list-section {
  background-color: #ffffff;
  padding: 30rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.service-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.service-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.service-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.info-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
  min-width: 0;
}

.service-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-desc {
  font-size: 24rpx;
  color: #999999;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.info-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.service-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.service-price {
  color: #f56c6c;
  font-size: 28rpx;
  font-weight: bold;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  color: #999999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.divider {
  width: 1rpx;
  height: 10rpx;
  background-color: #ddd;
  flex-shrink: 0;
}

/* 自定义预约按钮 */
.book-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 28rpx;
  text-align: center;
  flex-shrink: 0;
  min-width: 90rpx;
  box-shadow: 0 2rpx 8rpx rgba(64, 158, 255, 0.3);
}

.book-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #f3f3f3;
  border-top: 3rpx solid #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.meta-row.secondary {
  font-size: 22rpx;
  color: #999999;
  gap: 16rpx;
}

.service-price {
  color: #f56c6c;
  font-size: 36rpx;
  font-weight: bold;
}

.service-sales,
.service-duration {
  font-size: 22rpx;
  color: #999999;
}

.select-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #409eff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
  text-align: center;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 抽屉样式 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.drawer-content {
  width: 100%;
  max-height: 80vh;
  background-color: #ffffff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-left,
.header-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-right {
  justify-content: flex-end;
}

.drawer-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.close-icon {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.drawer-body {
  height: calc(80vh - 120rpx);
}

.companion-scroll {
  height: 100%;
  padding: 20rpx 0;
}

.companion-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 20rpx;
}

.companion-card:active {
  background-color: #f9f9f9;
}

.companion-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 3rpx solid #409eff;
}

.companion-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.tag.female {
  background-color: #f56c6c;
}

.tag:not(.female) {
  background-color: #409eff;
}

.tag.age {
  background-color: #e6a23c;
}

.tag.exp {
  background-color: #67c23a;
}

.stats-row {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999999;
}

.intro {
  font-size: 24rpx;
  color: #666666;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.select-icon {
  flex-shrink: 0;
}

.select-icon .icon {
  font-size: 48rpx;
  color: #409eff;
  font-weight: 300;
}