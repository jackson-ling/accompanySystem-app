/* pages/apply-companion/apply-companion.wxss */

.apply-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  display: flex;
  flex-direction: column;
}

/* 头部导航 */
.header {
  background-color: #fff;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.placeholder {
  width: 48rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: calc(80rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

/* 头像上传 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-upload {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f5f7fa;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.avatar-text {
  font-size: 24rpx;
  color: #999;
}

/* 表单区域 */
.section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  display: block;
}

.section-title text {
  color: #f56c6c;
  margin-left: 4rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.label text {
  color: #f56c6c;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid transparent;
  transition: border-color 0.3s;
}

.input:focus {
  border-color: #409eff;
  background-color: #fff;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid transparent;
  transition: border-color 0.3s;
}

.textarea:focus {
  border-color: #409eff;
  background-color: #fff;
}

/* 性别选择 */
.gender-options {
  display: flex;
  gap: 24rpx;
}

.gender-option {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e4e7ed;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.gender-option.active {
  border-color: #409eff;
  background-color: #ecf5ff;
  color: #409eff;
}

/* 标签选择 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 32rpx;
  background-color: #f7f8fa;
  border: 2rpx solid #e4e7ed;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.tag-item.selected {
  background-color: #ecf5ff;
  border-color: #409eff;
  color: #409eff;
}

/* 上传区域 */
.upload-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.upload-item {
  aspect-ratio: 16/9;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f7f8fa;
  border: 2rpx dashed #e4e7ed;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s;
}

.upload-item:active {
  opacity: 0.8;
}

.upload-item.full-width {
  aspect-ratio: 16/9;
}

.upload-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

/* 提交按钮 */
.submit-section {
  margin-top: 32rpx;
}

.submit-btn {
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.3);
}