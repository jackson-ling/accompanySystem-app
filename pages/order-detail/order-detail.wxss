.container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: calc(30rpx + constant(safe-area-inset-top));
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f5f5f5;
}

.header-left {
  width: 60rpx;
}

.nav-header .title {
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-header .placeholder {
  width: 60rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.content {
  padding: 20rpx;
}

.status-card {
  background: linear-gradient(135deg, #409eff, #79bbff);
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.status-card.status-pending {
  background: linear-gradient(135deg, #e6a23c, #f0c78a);
}

.status-card.status-wait {
  background: linear-gradient(135deg, #409eff, #79bbff);
}

.status-card.status-process {
  background: linear-gradient(135deg, #67c23a, #95d475);
}

.status-card.status-success {
  background: linear-gradient(135deg, #67c23a, #95d475);
}

.status-card.status-refund {
  background: linear-gradient(135deg, #f56c6c, #f89898);
}

.status-card.status-cancel {
  background: linear-gradient(135deg, #909399, #b1b3b8);
}

.status-text {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.section-card {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.service-info {
  display: flex;
  gap: 20rpx;
  position: relative;
}

.service-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.info-middle {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.service-intro {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.service-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.view-detail {
  position: absolute;
  top: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #409eff;
}

.price {
  position: absolute;
  bottom: 0;
  right: 0;
  font-size: 36rpx;
  font-weight: bold;
  color: #f56c6c;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-item .label {
  font-size: 28rpx;
  color: #666;
}

.info-item .value {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.companion-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.copy-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.copy-btn {
  color: #409eff;
  font-size: 24rpx;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.action-btn {
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
}

.action-btn.secondary {
  background-color: #f5f7fa;
  color: #666;
  border: 1rpx solid #e4e7ed;
}