.container {
  background-color: #fff;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: calc(30rpx + constant(safe-area-inset-top));
  padding-top: calc(30rpx + env(safe-area-inset-top));
  background-color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header-left {
  width: 80rpx;
}

.page-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.header-right {
  width: 80rpx;
}

.cover-image-container {
  width: 100%;
  padding-bottom: 60%;
  position: relative;
}

.cover-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.profile-section {
  padding: 0 30rpx;
  margin-top: 30rpx;
  position: relative;
  z-index: 10;
  margin-bottom: 30rpx;
}

.info-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 30rpx;
}

.left-avatar {
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.center-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 10rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.gender-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}

.gender-icon.female {
  background-color: #ff6699;
}

.gender-icon.male {
  background-color: #409eff;
}

.age {
  font-size: 26rpx;
  color: #666;
}

.tags-row {
  display: flex;
  gap: 12rpx;
}

.experience-tag {
  font-size: 22rpx;
  color: #fff;
  background-color: #409eff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.right-action {
  flex-shrink: 0;
}

.right-action .heart-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
}

.heart-icon {
  font-size: 56rpx;
  color: #999;
}

.heart-icon.active {
  color: #f56c6c;
}

.card-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background-color: #eee;
}

.intro-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.intro-box {
  background-color: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
}

.intro-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  text-align: justify;
  display: block;
}

.intro-content.collapsed {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.expand-btn {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: #409eff;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.expand-btn .is-expanded {
  transform: rotate(180deg);
}

.detail-tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 2rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
  color: #666;
}

.tab-item.active {
  color: #409eff;
  font-weight: bold;
  border-bottom: 4rpx solid #409eff;
}

.tab-content {
  padding: 30rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.service-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  padding: 20rpx;
  gap: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.service-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  display: block;
  margin-bottom: 16rpx;
}

.service-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-price {
  color: #f56c6c;
  font-size: 32rpx;
  font-weight: bold;
}

.book-btn {
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.2);
  white-space: nowrap;
}

.comment-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.comment-item {
  padding: 30rpx 0;
  border-bottom: 2rpx solid #eee;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.username {
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
  color: #333;
}

.score-display {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.score-text {
  font-size: 28rpx;
  color: #f7ba2a;
  font-weight: bold;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.comment-date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #409eff, #79bbff);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.3);
}