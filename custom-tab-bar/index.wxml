<!-- custom-tab-bar/index.wxml -->
<view class="tab-bar">
  <view 
    wx:for="{{list}}" 
    wx:key="pagePath" 
    class="tab-bar-item {{selected === index ? 'active' : ''}}" 
    data-path="{{item.pagePath}}" 
    data-index="{{index}}" 
    bindtap="switchTab"
  >
    <van-icon name="{{item.iconName}}" size="22" color="{{selected === index ? '#409eff' : '#999'}}" />
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>